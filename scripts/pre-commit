#!/bin/sh
# Pre-commit checks:
#   1. cargo clippy — no warnings allowed
#   2. File-size gate — no .rs file > 600 lines
#   3. FEATURES.md must be staged whenever src/ files change
#   4. Cargo.toml version must be bumped whenever src/ files change
#
# Install: scripts/install-hooks.sh

# ── 1. Clippy ────────────────────────────────────────────────────────────────
src_staged=$(git diff --cached --name-only | grep '^src/.*\.rs$')
if [ -n "$src_staged" ]; then
    echo "  ◌ Running cargo clippy…"
    if ! cargo clippy --all-targets --quiet -- -D warnings 2>&1; then
        echo ""
        echo "  ✗ clippy found issues — fix them before committing."
        echo "  To skip: git commit --no-verify"
        echo ""
        exit 1
    fi
    echo "  ✓ clippy passed"
fi

# ── 2. File-size gate ────────────────────────────────────────────────────────
MAX_LINES=600
oversized=""
for f in $(git diff --cached --name-only | grep '\.rs$'); do
    if [ -f "$f" ]; then
        lines=$(wc -l < "$f")
        if [ "$lines" -gt "$MAX_LINES" ]; then
            oversized="$oversized\n      $f ($lines lines)"
        fi
    fi
done

if [ -n "$oversized" ]; then
    echo ""
    echo "  ✗ Files exceed $MAX_LINES lines — split into smaller modules first:"
    printf "%b\n" "$oversized"
    echo ""
    echo "  To skip: git commit --no-verify"
    echo ""
    exit 1
fi

# ── 3. FEATURES.md gate ──────────────────────────────────────────────────────
features_staged=$(git diff --cached --name-only | grep '^FEATURES\.md$')

if [ -n "$src_staged" ] && [ -z "$features_staged" ]; then
    echo ""
    echo "  ✗ FEATURES.md not staged — src/ files changed:"
    echo "$src_staged" | sed 's/^/      /'
    echo ""
    echo "  Update FEATURES.md (Implemented or Planned), then:"
    echo "    git add FEATURES.md"
    echo ""
    echo "  To skip this check: git commit --no-verify"
    echo ""
    exit 1
fi

# ── 4. Version bump gate ─────────────────────────────────────────────────────
cargo_staged=$(git diff --cached --name-only | grep '^Cargo\.toml$')

if [ -n "$src_staged" ] && [ -z "$cargo_staged" ]; then
    current=$(grep '^version' Cargo.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')
    echo ""
    echo "  ✗ Cargo.toml not staged — bump the version when src/ changes."
    echo "  Current: $current"
    echo "  Edit Cargo.toml (patch for fixes, minor for new features), then:"
    echo "    git add Cargo.toml"
    echo ""
    echo "  To skip: git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
